{
    "name": "theadmin/theadmin-plugin",
    "description": "The Admin 后台管理系统核心插件，基于 Workerman/Webman",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "The Admin",
            "email": "admin@example.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/pagination": "^10.0|^11.0",
        "illuminate/events": "^10.0|^11.0",
        "firebase/php-jwt": "^6.11",
        "symfony/var-dumper": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "plugin\\theadmin\\": "app/"
        },
        "files": [
            "app/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "plugin\\theadmin\\tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "post-autoload-dump": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "webman": {
            "name": "theadmin",
            "title": "The Admin 核心插件",
            "version": "1.0.0"
        }
    }
}
